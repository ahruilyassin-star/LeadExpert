{%- assign coll = collections[section.settings.collection_handle] -%}

<section class="epg-wrap" id="epg-{{ section.id }}">
  <div class="epg-inner">
    <div class="epg-header">
      <div class="epg-header__text">
        <span class="epg-eyebrow">{{ section.settings.eyebrow | default: 'Bestsellers' }}</span>
        <h2 class="epg-title">{{ section.settings.title | default: 'Los más vendidos' }}</h2>
      </div>
      <a class="epg-header__link" href="{{ section.settings.cta_url | default: '/collections/bestsellers-esencias-de-dubai' }}">
        {{ section.settings.cta_text | default: 'Ver todo' }}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    <div class="epg-grid">
      {%- if coll != blank and coll.products.size > 0 -%}
        {%- for product in coll.products limit: 8 -%}
          {%- assign is_on_sale = false -%}
          {%- if product.compare_at_price > product.price -%}
            {%- assign is_on_sale = true -%}
          {%- endif -%}
          <a class="epg-card" href="{{ product.url }}" data-idx="{{ forloop.index0 }}" aria-label="{{ product.title }}">
            <div class="epg-card__img-wrap">
              {%- if is_on_sale -%}
                <span class="epg-card__badge">Oferta</span>
              {%- endif -%}
              {%- if product.featured_image -%}
                <img class="epg-card__img" src="{{ product.featured_image | img_url: '500x' }}" alt="{{ product.featured_image.alt | default: product.title }}" loading="lazy" width="500" height="625">
              {%- else -%}
                <div class="epg-card__img epg-card__img--ph"></div>
              {%- endif -%}
              <div class="epg-card__quick">
                <span>Ver producto</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            </div>
            <div class="epg-card__body">
              {%- if product.vendor != blank -%}
                <span class="epg-card__vendor">{{ product.vendor }}</span>
              {%- endif -%}
              <h3 class="epg-card__title">{{ product.title }}</h3>
              <div class="epg-card__prices">
                {%- if is_on_sale -%}
                  <span class="epg-card__price epg-card__price--sale">{{ product.price | money }}</span>
                  <span class="epg-card__price epg-card__price--compare">{{ product.compare_at_price | money }}</span>
                {%- else -%}
                  <span class="epg-card__price">{{ product.price | money }}</span>
                {%- endif -%}
              </div>
            </div>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..8) -%}
          <div class="epg-card epg-card--empty" data-idx="{{ forloop.index0 }}">
            <div class="epg-card__img-wrap"><div class="epg-card__img epg-card__img--ph"></div></div>
            <div class="epg-card__body">
              <span class="epg-card__vendor">Esencias de Dubai</span>
              <h3 class="epg-card__title">Fragancia Árabe Premium</h3>
              <div class="epg-card__prices"><span class="epg-card__price">desde 39,00 €</span></div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<style>
#epg-{{ section.id }} {background:#fff;padding:100px 48px;font-family:-apple-system,BlinkMacSystemFont,'Inter','Segoe UI',sans-serif;}
#epg-{{ section.id }} .epg-inner {max-width:1380px;margin:0 auto;}
#epg-{{ section.id }} .epg-header {display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:48px;gap:24px;flex-wrap:wrap;}
#epg-{{ section.id }} .epg-eyebrow {display:block;font-size:0.72rem;font-weight:500;letter-spacing:0.2em;text-transform:uppercase;color:#9a9a9a;margin-bottom:12px;}
#epg-{{ section.id }} .epg-title {font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(1.9rem,3.4vw,2.6rem);font-weight:400;color:#0a0a0a;margin:0;letter-spacing:-0.02em;line-height:1.1;}
#epg-{{ section.id }} .epg-header__link {display:inline-flex;align-items:center;gap:8px;font-size:0.82rem;font-weight:500;letter-spacing:0.06em;text-transform:uppercase;color:#0a0a0a;text-decoration:none;border-bottom:1px solid #0a0a0a;padding-bottom:3px;transition:gap 0.3s;}
#epg-{{ section.id }} .epg-header__link:hover {gap:12px;}
#epg-{{ section.id }} .epg-grid {display:grid;grid-template-columns:repeat(4,1fr);gap:24px;}
#epg-{{ section.id }} .epg-card {display:block;text-decoration:none;background:#fff;opacity:0;transform:translateY(20px);transition:opacity 0.6s,transform 0.6s;}
#epg-{{ section.id }} .epg-card.epg--visible {opacity:1;transform:translateY(0);}
#epg-{{ section.id }} .epg-card__img-wrap {position:relative;aspect-ratio:4/5;overflow:hidden;background:#f7f7f7;margin-bottom:16px;}
#epg-{{ section.id }} .epg-card__img {width:100%;height:100%;object-fit:cover;display:block;transition:transform 0.7s cubic-bezier(0.25,0.46,0.45,0.94);}
#epg-{{ section.id }} .epg-card:hover .epg-card__img {transform:scale(1.05);}
#epg-{{ section.id }} .epg-card__img--ph {background:linear-gradient(135deg,#f5f5f5,#ebebeb);}
#epg-{{ section.id }} .epg-card__badge {position:absolute;top:14px;left:14px;z-index:3;background:#0a0a0a;color:#fff;font-size:0.62rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;padding:5px 10px;border-radius:2px;}
#epg-{{ section.id }} .epg-card__quick {position:absolute;left:14px;right:14px;bottom:14px;display:flex;align-items:center;justify-content:center;gap:8px;padding:12px;background:rgba(10,10,10,0.95);backdrop-filter:blur(8px);color:#fff;font-size:0.7rem;font-weight:500;letter-spacing:0.12em;text-transform:uppercase;border-radius:2px;opacity:0;transform:translateY(8px);transition:all 0.35s cubic-bezier(0.25,0.46,0.45,0.94);}
#epg-{{ section.id }} .epg-card:hover .epg-card__quick {opacity:1;transform:translateY(0);}
#epg-{{ section.id }} .epg-card__body {padding:0 2px;}
#epg-{{ section.id }} .epg-card__vendor {display:block;font-size:0.66rem;font-weight:500;letter-spacing:0.16em;text-transform:uppercase;color:#9a9a9a;margin-bottom:8px;}
#epg-{{ section.id }} .epg-card__title {font-family:'Cormorant Garamond',Georgia,serif;font-size:1rem;font-weight:400;color:#0a0a0a;margin:0 0 10px;line-height:1.35;letter-spacing:-0.01em;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;min-height:2.7em;}
#epg-{{ section.id }} .epg-card:hover .epg-card__title {color:#262626;}
#epg-{{ section.id }} .epg-card__prices {display:flex;align-items:baseline;gap:8px;}
#epg-{{ section.id }} .epg-card__price {font-size:0.95rem;font-weight:600;color:#0a0a0a;letter-spacing:-0.01em;}
#epg-{{ section.id }} .epg-card__price--sale {color:#c9333a;}
#epg-{{ section.id }} .epg-card__price--compare {font-size:0.8rem;font-weight:400;color:#9a9a9a;text-decoration:line-through;}
@media(max-width:1100px){
#epg-{{ section.id }} .epg-grid {grid-template-columns:repeat(3,1fr);}
}
@media(max-width:768px){
#epg-{{ section.id }} {padding:64px 20px;}
#epg-{{ section.id }} .epg-grid {grid-template-columns:repeat(2,1fr);gap:14px;}
#epg-{{ section.id }} .epg-card__title {font-size:0.9rem;}
#epg-{{ section.id }} .epg-card__quick {display:none;}
}
</style>

<script>
(function(){
  var sid = '{{ section.id }}';
  var wrap = document.getElementById('epg-' + sid);
  if (!wrap) return;
  var cards = wrap.querySelectorAll('.epg-card');
  var obs = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if (e.isIntersecting) {
        var c = e.target;
        var idx = parseInt(c.getAttribute('data-idx'), 10) || 0;
        setTimeout(function(){ c.classList.add('epg--visible'); }, idx * 70);
        obs.unobserve(c);
      }
    });
  }, { threshold: 0.1 });
  cards.forEach(function(c){ obs.observe(c); });
})();
</script>

{% schema %}
{
  "name": "ED – Product Grid",
  "tag": "section",
  "class": "ed-section",
  "settings": [
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Bestsellers"},
    {"type":"text","id":"title","label":"Title","default":"Los más vendidos"},
    {"type":"text","id":"collection_handle","label":"Collection Handle","default":"bestsellers-esencias-de-dubai"},
    {"type":"text","id":"cta_text","label":"CTA Text","default":"Ver todo"},
    {"type":"url","id":"cta_url","label":"CTA URL"}
  ],
  "presets": [
    {"name":"ED – Product Grid"}
  ]
}
{% endschema %}
