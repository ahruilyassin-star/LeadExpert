<section class="ech-wrap" id="ech-{{ section.id }}">
  <div class="ech-inner">
    <div class="ech-text">
      <span class="ech-eyebrow">{{ section.settings.eyebrow | default: 'Perfumería Árabe' }}</span>
      <h1 class="ech-title">
        <span class="ech-title__line1">{{ section.settings.heading1 | default: 'Esencias' }}</span>
        <span class="ech-title__line2">{{ section.settings.heading2 | default: 'de Dubai' }}</span>
      </h1>
      <p class="ech-sub">{{ section.settings.subheading | default: 'Fragancias auténticas del Oriente Medio, seleccionadas a mano en los zocos de Dubai, Abu Dhabi y Mascate.' }}</p>
      <div class="ech-ctas">
        <a class="ech-btn ech-btn--primary" href="{{ section.settings.cta1_url | default: '/collections/all' }}">
          <span>{{ section.settings.cta1_text | default: 'Comprar ahora' }}</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a class="ech-btn ech-btn--secondary" href="{{ section.settings.cta2_url | default: '/collections/perfumes-con-oud' }}">
          {{ section.settings.cta2_text | default: 'Descubrir Oud' }}
        </a>
      </div>
      <div class="ech-meta">
        <div class="ech-meta__item"><strong>194</strong><span>Fragancias</span></div>
        <div class="ech-meta__divider"></div>
        <div class="ech-meta__item"><strong>10+</strong><span>Marcas</span></div>
        <div class="ech-meta__divider"></div>
        <div class="ech-meta__item"><strong>48h</strong><span>Envío</span></div>
      </div>
    </div>
    <div class="ech-visual">
      <div class="ech-visual__frame">
        {%- if section.settings.image != blank -%}
          <img class="ech-img" src="{{ section.settings.image | img_url: '900x' }}" alt="{{ section.settings.heading1 }}" loading="eager" width="900" height="1200">
        {%- else -%}
          <div class="ech-img ech-img--ph"></div>
        {%- endif -%}
      </div>
      <span class="ech-tag">Nuevo · Anno 2026</span>
    </div>
  </div>
</section>

<style>
#ech-{{ section.id }} {background:#fff;padding:80px 48px;min-height:88vh;display:flex;align-items:center;font-family:-apple-system,BlinkMacSystemFont,'Inter','Segoe UI',sans-serif;}
#ech-{{ section.id }} .ech-inner {display:grid;grid-template-columns:1.05fr 1fr;gap:80px;max-width:1380px;margin:0 auto;width:100%;align-items:center;}
#ech-{{ section.id }} .ech-text {opacity:0;transform:translateY(20px);animation:ech-in 0.9s cubic-bezier(0.25,0.46,0.45,0.94) 0.15s forwards;}
#ech-{{ section.id }} .ech-eyebrow {display:inline-block;font-size:0.7rem;font-weight:500;letter-spacing:0.22em;text-transform:uppercase;color:#0a0a0a;padding:7px 16px;border:1px solid #e5e5e5;border-radius:100px;margin-bottom:36px;}
#ech-{{ section.id }} .ech-title {font-family:'Playfair Display',Georgia,serif;font-size:clamp(2.6rem,6.2vw,5.4rem);font-weight:400;line-height:1.02;color:#0a0a0a;margin:0 0 36px;letter-spacing:-0.025em;}
#ech-{{ section.id }} .ech-title__line1 {display:block;}
#ech-{{ section.id }} .ech-title__line2 {display:block;font-style:italic;color:#4a4a4a;}
#ech-{{ section.id }} .ech-sub {font-size:1.02rem;line-height:1.7;color:#6b6b6b;max-width:460px;margin:0 0 42px;font-weight:400;}
#ech-{{ section.id }} .ech-ctas {display:flex;gap:12px;flex-wrap:wrap;margin-bottom:64px;}
#ech-{{ section.id }} .ech-btn {display:inline-flex;align-items:center;gap:10px;padding:16px 30px;font-size:0.82rem;font-weight:500;letter-spacing:0.06em;text-decoration:none;transition:all 0.35s cubic-bezier(0.25,0.46,0.45,0.94);border-radius:2px;text-transform:uppercase;}
#ech-{{ section.id }} .ech-btn--primary {background:#0a0a0a;color:#fff;border:1px solid #0a0a0a;}
#ech-{{ section.id }} .ech-btn--primary:hover {background:#262626;transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,0.12);}
#ech-{{ section.id }} .ech-btn svg {transition:transform 0.35s cubic-bezier(0.25,0.46,0.45,0.94);}
#ech-{{ section.id }} .ech-btn--primary:hover svg {transform:translateX(4px);}
#ech-{{ section.id }} .ech-btn--secondary {background:transparent;color:#0a0a0a;border:1px solid #d6d6d6;}
#ech-{{ section.id }} .ech-btn--secondary:hover {border-color:#0a0a0a;background:#0a0a0a;color:#fff;transform:translateY(-2px);}
#ech-{{ section.id }} .ech-meta {display:flex;align-items:center;gap:28px;padding-top:32px;border-top:1px solid #ebebeb;max-width:440px;}
#ech-{{ section.id }} .ech-meta__item {display:flex;flex-direction:column;}
#ech-{{ section.id }} .ech-meta__item strong {font-family:'Playfair Display',Georgia,serif;font-size:1.55rem;font-weight:400;color:#0a0a0a;line-height:1;}
#ech-{{ section.id }} .ech-meta__item span {font-size:0.72rem;letter-spacing:0.14em;text-transform:uppercase;color:#9a9a9a;margin-top:6px;}
#ech-{{ section.id }} .ech-meta__divider {width:1px;height:32px;background:#ebebeb;}
#ech-{{ section.id }} .ech-visual {position:relative;opacity:0;transform:translateY(30px);animation:ech-in 1.1s cubic-bezier(0.25,0.46,0.45,0.94) 0.35s forwards;}
#ech-{{ section.id }} .ech-visual__frame {position:relative;overflow:hidden;border-radius:2px;background:#f5f5f5;}
#ech-{{ section.id }} .ech-img {width:100%;height:auto;display:block;aspect-ratio:3/4;object-fit:cover;transition:transform 1.4s cubic-bezier(0.25,0.46,0.45,0.94);}
#ech-{{ section.id }} .ech-visual:hover .ech-img {transform:scale(1.03);}
#ech-{{ section.id }} .ech-img--ph {width:100%;aspect-ratio:3/4;background:linear-gradient(135deg,#f5f5f5,#ebebeb);}
#ech-{{ section.id }} .ech-tag {position:absolute;top:24px;right:24px;background:rgba(255,255,255,0.95);backdrop-filter:blur(10px);padding:8px 16px;border-radius:100px;font-size:0.7rem;font-weight:500;letter-spacing:0.12em;text-transform:uppercase;color:#0a0a0a;}
@keyframes ech-in {to {opacity:1;transform:translateY(0);}}
@media(max-width:960px){
#ech-{{ section.id }} {padding:48px 20px;min-height:auto;}
#ech-{{ section.id }} .ech-inner {grid-template-columns:1fr;gap:40px;}
#ech-{{ section.id }} .ech-visual {order:-1;}
#ech-{{ section.id }} .ech-img {aspect-ratio:4/3;}
#ech-{{ section.id }} .ech-meta {gap:20px;}
#ech-{{ section.id }} .ech-meta__item strong {font-size:1.3rem;}
#ech-{{ section.id }} .ech-btn {padding:14px 24px;font-size:0.78rem;}
}
</style>

{% schema %}
{
  "name": "ED – Clean Hero",
  "tag": "section",
  "class": "ed-section",
  "settings": [
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Perfumería Árabe"},
    {"type":"text","id":"heading1","label":"Heading line 1","default":"Esencias"},
    {"type":"text","id":"heading2","label":"Heading line 2 (italic)","default":"de Dubai"},
    {"type":"textarea","id":"subheading","label":"Subheading","default":"Fragancias auténticas del Oriente Medio, seleccionadas a mano en los zocos de Dubai, Abu Dhabi y Mascate."},
    {"type":"text","id":"cta1_text","label":"CTA 1 text","default":"Comprar ahora"},
    {"type":"url","id":"cta1_url","label":"CTA 1 URL"},
    {"type":"text","id":"cta2_text","label":"CTA 2 text","default":"Descubrir Oud"},
    {"type":"url","id":"cta2_url","label":"CTA 2 URL"},
    {"type":"image_picker","id":"image","label":"Hero image"}
  ],
  "presets": [
    {"name":"ED – Clean Hero"}
  ]
}
{% endschema %}
