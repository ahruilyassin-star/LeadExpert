{%- assign coll = collections[section.settings.collection_handle] -%}

<div class="eds-wrap" id="eds-{{ section.id }}">

  <div class="eds-header">
    <div class="eds-eyebrow">
      <span class="eds-eyebrow__line"></span>
      <span class="eds-eyebrow__text">{{ section.settings.eyebrow | default: 'Nuestros Favoritos' }}</span>
      <span class="eds-eyebrow__line"></span>
    </div>
    <h2 class="eds-title">{{ section.settings.title | default: 'Los Más Vendidos' }}</h2>
    <p class="eds-subtitle">{{ section.settings.subtitle | default: 'Las fragancias que más enamoran' }}</p>
  </div>

  <div class="eds-grid">
    {%- if coll != blank and coll.products.size > 0 -%}
      {%- for product in coll.products limit: 8 -%}
        {%- assign is_on_sale = false -%}
        {%- if product.compare_at_price > product.price -%}
          {%- assign is_on_sale = true -%}
        {%- endif -%}
        <a class="eds-card" href="{{ product.url }}" data-idx="{{ forloop.index0 }}" aria-label="{{ product.title }}">
          <div class="eds-card__badge {%- if is_on_sale %} eds-card__badge--sale{%- else %} eds-card__badge--pop{%- endif %}">
            {%- if is_on_sale -%}Oferta{%- else -%}Popular{%- endif -%}
          </div>
          <div class="eds-card__img-wrap">
            {%- if product.featured_image -%}
              <img class="eds-card__img" src="{{ product.featured_image | img_url: '500x' }}" alt="{{ product.featured_image.alt | default: product.title }}" loading="lazy" width="500" height="667">
            {%- else -%}
              <div class="eds-card__img eds-card__img--ph"></div>
            {%- endif -%}
          </div>
          <div class="eds-card__glare"></div>
          <div class="eds-card__body">
            {%- if product.vendor != blank -%}
              <span class="eds-card__vendor">{{ product.vendor }}</span>
            {%- endif -%}
            <h3 class="eds-card__title">{{ product.title }}</h3>
            <div class="eds-card__price-row">
              {%- if is_on_sale -%}
                <span class="eds-card__price eds-card__price--sale">{{ product.price | money }}</span>
                <span class="eds-card__price eds-card__price--compare">{{ product.compare_at_price | money }}</span>
              {%- else -%}
                <span class="eds-card__price">{{ product.price | money }}</span>
              {%- endif -%}
            </div>
            <span class="eds-card__link">Ver producto <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
          </div>
        </a>
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..8) -%}
        <div class="eds-card eds-card--empty" data-idx="{{ forloop.index0 }}">
          <div class="eds-card__img-wrap">
            <div class="eds-card__img eds-card__img--ph"></div>
          </div>
          <div class="eds-card__body">
            <span class="eds-card__vendor">Esencias de Dubai</span>
            <h3 class="eds-card__title">Fragancia Árabe Premium</h3>
            <div class="eds-card__price-row"><span class="eds-card__price">desde 39,00 €</span></div>
            <span class="eds-card__link">Ver producto <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>

  <div class="eds-footer">
    <a class="eds-footer__cta" href="{{ section.settings.cta_url | default: '/collections/bestsellers-esencias-de-dubai' }}">
      {{ section.settings.cta_text | default: 'Ver todos los bestsellers' }}
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>

</div>

<style>
#eds-{{ section.id }} {background:linear-gradient(180deg,#080808 0%,#0d0d0d 100%);padding:80px 40px;}
#eds-{{ section.id }} .eds-header {text-align:center;margin-bottom:56px;}
#eds-{{ section.id }} .eds-eyebrow {display:flex;align-items:center;justify-content:center;gap:16px;margin-bottom:20px;}
#eds-{{ section.id }} .eds-eyebrow__line {flex:0 0 48px;height:1px;background:linear-gradient(90deg,transparent,#c9a84c);}
#eds-{{ section.id }} .eds-eyebrow__line:last-child {background:linear-gradient(90deg,#c9a84c,transparent);}
#eds-{{ section.id }} .eds-eyebrow__text {font-family:'Playfair Display',Georgia,serif;font-size:0.75rem;letter-spacing:0.25em;text-transform:uppercase;color:#c9a84c;}
#eds-{{ section.id }} .eds-title {font-family:'Playfair Display',Georgia,serif;font-size:clamp(2rem,4vw,3rem);font-weight:400;color:#fff;margin:0 0 12px;}
#eds-{{ section.id }} .eds-subtitle {font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;font-size:1rem;color:rgba(255,255,255,0.5);margin:0;}
#eds-{{ section.id }} .eds-grid {display:grid;grid-template-columns:repeat(4,1fr);gap:20px;max-width:1400px;margin:0 auto;}
#eds-{{ section.id }} .eds-card {position:relative;display:block;text-decoration:none;border-radius:4px;overflow:hidden;background:#111;border:1px solid rgba(255,255,255,0.06);cursor:pointer;transform-style:preserve-3d;will-change:transform;opacity:0;transform:translateY(24px);transition:box-shadow 0.4s,border-color 0.4s;}
#eds-{{ section.id }} .eds-card.eds--visible {opacity:1;transform:translateY(0);}
#eds-{{ section.id }} .eds-card:hover {box-shadow:0 20px 60px rgba(201,168,76,0.2);border-color:rgba(201,168,76,0.25);}
#eds-{{ section.id }} .eds-card__badge {position:absolute;top:12px;left:12px;z-index:5;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;font-size:0.65rem;letter-spacing:0.1em;text-transform:uppercase;font-weight:700;padding:4px 10px;border-radius:2px;}
#eds-{{ section.id }} .eds-card__badge--sale {background:#c9333a;color:#fff;}
#eds-{{ section.id }} .eds-card__badge--pop {background:linear-gradient(135deg,#c9a84c,#e8c96e);color:#060606;}
#eds-{{ section.id }} .eds-card__img-wrap {position:relative;aspect-ratio:3/4;overflow:hidden;background:#1a1a1a;}
#eds-{{ section.id }} .eds-card__img {width:100%;height:100%;object-fit:cover;display:block;transition:transform 0.5s cubic-bezier(0.25,0.46,0.45,0.94);}
#eds-{{ section.id }} .eds-card:hover .eds-card__img {transform:scale(1.05);}
#eds-{{ section.id }} .eds-card__img--ph {width:100%;height:100%;background:linear-gradient(135deg,#1c1c1c,#2a2a2a);}
#eds-{{ section.id }} .eds-card__glare {position:absolute;top:0;left:0;width:100%;height:75%;pointer-events:none;z-index:4;opacity:0;transition:opacity 0.3s;background:radial-gradient(circle at 50% 30%,rgba(201,168,76,0.18) 0%,transparent 60%);}
#eds-{{ section.id }} .eds-card:hover .eds-card__glare {opacity:1;}
#eds-{{ section.id }} .eds-card__body {padding:16px;position:relative;z-index:3;}
#eds-{{ section.id }} .eds-card__vendor {display:block;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;color:#c9a84c;margin-bottom:6px;}
#eds-{{ section.id }} .eds-card__title {font-family:'Playfair Display',Georgia,serif;font-size:0.95rem;font-weight:400;color:#fff;margin:0 0 10px;line-height:1.35;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
#eds-{{ section.id }} .eds-card__price-row {display:flex;align-items:center;gap:8px;margin-bottom:12px;}
#eds-{{ section.id }} .eds-card__price {font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;font-size:0.95rem;font-weight:600;color:#fff;}
#eds-{{ section.id }} .eds-card__price--sale {color:#c9a84c;}
#eds-{{ section.id }} .eds-card__price--compare {font-size:0.8rem;font-weight:400;color:rgba(255,255,255,0.35);text-decoration:line-through;}
#eds-{{ section.id }} .eds-card__link {display:inline-flex;align-items:center;gap:5px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;font-size:0.75rem;letter-spacing:0.08em;text-transform:uppercase;color:rgba(201,168,76,0.7);transition:color 0.3s;}
#eds-{{ section.id }} .eds-card:hover .eds-card__link {color:#c9a84c;}
#eds-{{ section.id }} .eds-card__link svg {transition:transform 0.3s;}
#eds-{{ section.id }} .eds-card:hover .eds-card__link svg {transform:translateX(3px);}
#eds-{{ section.id }} .eds-footer {text-align:center;margin-top:48px;}
#eds-{{ section.id }} .eds-footer__cta {display:inline-flex;align-items:center;gap:8px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;font-size:0.85rem;letter-spacing:0.12em;text-transform:uppercase;color:#c9a84c;text-decoration:none;border-bottom:1px solid rgba(201,168,76,0.3);padding-bottom:4px;transition:all 0.3s;}
#eds-{{ section.id }} .eds-footer__cta:hover {border-color:#c9a84c;gap:12px;}
#eds-{{ section.id }} .eds-footer__cta svg {transition:transform 0.3s;}
#eds-{{ section.id }} .eds-footer__cta:hover svg {transform:translateX(4px);}
@media(max-width:1200px){
#eds-{{ section.id }} .eds-grid {grid-template-columns:repeat(3,1fr);}
}
@media(max-width:900px){
#eds-{{ section.id }} .eds-grid {grid-template-columns:repeat(2,1fr);}
}
@media(max-width:768px){
#eds-{{ section.id }} {padding:60px 16px;}
#eds-{{ section.id }} .eds-grid {grid-template-columns:repeat(2,1fr);gap:12px;}
}
@media(max-width:480px){
#eds-{{ section.id }} .eds-grid {grid-template-columns:1fr;}
}
</style>

<script>
(function(){
  var sid = '{{ section.id }}';
  var wrap = document.getElementById('eds-' + sid);
  if (!wrap) return;
  var cards = wrap.querySelectorAll('.eds-card');

  // ── Scroll-in animation ──────────────────────────────────────────
  var ioOpts = { threshold: 0.12 };
  var scrollObs = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        var card = entry.target;
        var idx = parseInt(card.getAttribute('data-idx'), 10) || 0;
        setTimeout(function() {
          card.classList.add('eds--visible');
          card.style.transition = 'opacity 0.6s, transform 0.6s, box-shadow 0.4s, border-color 0.4s';
        }, idx * 80);
        scrollObs.unobserve(card);
      }
    });
  }, ioOpts);
  cards.forEach(function(card) { scrollObs.observe(card); });

  // ── Per-card 3D tilt + glare ─────────────────────────────────────
  function lerp(a, b, t) { return a + (b - a) * t; }

  cards.forEach(function(card) {
    var glare = card.querySelector('.eds-card__glare');
    var curRX = 0, curRY = 0;
    var tgtRX = 0, tgtRY = 0;
    var hovered = false;
    var running = false;

    function tick() {
      curRX = lerp(curRX, tgtRX, 0.1);
      curRY = lerp(curRY, tgtRY, 0.1);
      card.style.transform = card.classList.contains('eds--visible')
        ? 'translateY(0) perspective(900px) rotateX(' + curRY + 'deg) rotateY(' + curRX + 'deg)'
        : 'translateY(24px) perspective(900px) rotateX(' + curRY + 'deg) rotateY(' + curRX + 'deg)';
      var dX = Math.abs(curRX - tgtRX);
      var dY = Math.abs(curRY - tgtRY);
      if (dX > 0.01 || dY > 0.01 || hovered) {
        requestAnimationFrame(tick);
      } else {
        if (card.classList.contains('eds--visible')) {
          card.style.transform = 'translateY(0)';
        }
        running = false;
      }
    }

    card.addEventListener('mousemove', function(e) {
      if (window.innerWidth < 768) return;
      var rect = card.getBoundingClientRect();
      var relX = (e.clientX - rect.left) / rect.width - 0.5;
      var relY = (e.clientY - rect.top) / rect.height - 0.5;
      tgtRX = relX * 12;
      tgtRY = -relY * 12;
      hovered = true;
      if (!running) { running = true; requestAnimationFrame(tick); }
      if (glare) {
        var gx = ((e.clientX - rect.left) / rect.width * 100).toFixed(1);
        var gy = ((e.clientY - rect.top) / rect.height * 100).toFixed(1);
        glare.style.background = 'radial-gradient(circle at ' + gx + '% ' + gy + '%, rgba(201,168,76,0.22) 0%, transparent 55%)';
      }
    });

    card.addEventListener('mouseleave', function() {
      tgtRX = 0;
      tgtRY = 0;
      hovered = false;
      if (!running) { running = true; requestAnimationFrame(tick); }
    });
  });
})();
</script>

{% schema %}
{
  "name": "ED – 3D Showcase",
  "tag": "section",
  "class": "ed-section",
  "settings": [
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Nuestros Favoritos"},
    {"type":"text","id":"title","label":"Title","default":"Los Más Vendidos"},
    {"type":"text","id":"subtitle","label":"Subtitle","default":"Las fragancias que más enamoran"},
    {"type":"text","id":"collection_handle","label":"Collection Handle","default":"bestsellers-esencias-de-dubai"},
    {"type":"text","id":"cta_text","label":"CTA Text","default":"Ver todos los bestsellers"},
    {"type":"url","id":"cta_url","label":"CTA URL"}
  ],
  "presets": [
    {"name":"ED – 3D Showcase"}
  ]
}
{% endschema %}
