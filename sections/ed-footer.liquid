<style>
.ed-footer{background:#1a1a1a;color:rgba(255,255,255,0.7);font-family:'Inter',sans-serif;font-size:14px;line-height:1.6}
.ed-footer__top{padding:64px 0 48px}
.ed-footer__inner{max-width:1200px;margin:0 auto;padding:0 24px;display:grid;grid-template-columns:1.6fr 1fr 1fr 1.2fr;gap:48px}
.ed-footer__logo{display:block;text-decoration:none;margin-bottom:16px}
.ed-footer__logo-text{display:block;font-family:'Cormorant Garamond',Georgia,serif;font-size:1.4rem;font-weight:400;color:#fff;letter-spacing:0.02em;line-height:1.2}
.ed-footer__logo-sub{display:block;font-size:10px;letter-spacing:0.15em;text-transform:uppercase;color:#c9a96e;margin-top:3px}
.ed-footer__desc{color:rgba(255,255,255,0.5);font-size:13px;line-height:1.7;margin:0 0 20px}
.ed-footer__social{display:flex;gap:12px;margin-bottom:20px}
.ed-footer__social-link{display:flex;align-items:center;justify-content:center;width:36px;height:36px;border:1px solid rgba(255,255,255,0.15);border-radius:50%;color:rgba(255,255,255,0.5);transition:all .2s;text-decoration:none}
.ed-footer__social-link:hover{border-color:#c9a96e;color:#c9a96e;background:rgba(201,169,110,0.1)}
.ed-footer__trust{display:flex;flex-direction:column;gap:6px}
.ed-footer__trust-badge{font-size:12px;color:rgba(255,255,255,0.4);letter-spacing:0.03em}
.ed-footer__heading{font-family:'Cormorant Garamond',Georgia,serif;font-size:1rem;font-weight:500;color:#fff;letter-spacing:0.08em;text-transform:uppercase;margin:0 0 18px}
.ed-footer__links{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px}
.ed-footer__links a{color:rgba(255,255,255,0.5);text-decoration:none;font-size:13px;transition:color .2s}
.ed-footer__links a:hover{color:#c9a96e}
.ed-footer__contact{display:flex;flex-direction:column;gap:10px}
.ed-footer__contact-link{display:flex;align-items:center;gap:8px;color:rgba(255,255,255,0.5);text-decoration:none;font-size:13px;transition:color .2s}
.ed-footer__contact-link:hover{color:#c9a96e}
.ed-footer__payment-bar{border-top:1px solid rgba(255,255,255,0.08);border-bottom:1px solid rgba(255,255,255,0.08);padding:16px 0}
.ed-footer__payment-inner{max-width:1200px;margin:0 auto;padding:0 24px;display:flex;align-items:center;gap:20px;flex-wrap:wrap}
.ed-footer__payment-label{font-size:12px;color:rgba(255,255,255,0.35);letter-spacing:0.05em;white-space:nowrap}
.ed-footer__payment-icons{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
.ed-footer__pay-icon{display:inline-flex;border-radius:4px;overflow:hidden;opacity:0.8;transition:opacity .2s}
.ed-footer__pay-icon:hover{opacity:1}
.ed-footer__bottom{padding:20px 0}
.ed-footer__bottom-inner{max-width:1200px;margin:0 auto;padding:0 24px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap}
.ed-footer__copy{margin:0;font-size:12px;color:rgba(255,255,255,0.3)}
.ed-footer__bottom-links{margin:0;display:flex;gap:12px;align-items:center;font-size:12px;color:rgba(255,255,255,0.25)}
.ed-footer__bottom-links a{color:rgba(255,255,255,0.3);text-decoration:none;transition:color .2s}
.ed-footer__bottom-links a:hover{color:#c9a96e}
.ed-footer__bottom-links span{color:rgba(255,255,255,0.15)}
@media(max-width:1024px){.ed-footer__inner{grid-template-columns:1fr 1fr;gap:40px}}
@media(max-width:640px){
  .ed-footer__inner{grid-template-columns:1fr;gap:32px}
  .ed-footer__top{padding:40px 0 32px}
  .ed-footer__bottom-inner{flex-direction:column;align-items:flex-start}
  .ed-footer__payment-inner{flex-direction:column;align-items:flex-start}
}
</style>

