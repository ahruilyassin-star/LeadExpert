# ============================================================
# SEO DASHBOARD - API KEYS CONFIGURATIE
# Kopieer dit bestand naar .env en vul je sleutels in
# ============================================================

# DataForSEO API - VERPLICHT voor keyword + backlink data
# Aanmaken op: https://dataforseo.com (gratis proefperiode)
# Kosten: ~€0.001-0.003 per query (vs €99+/maand Ahrefs)
DATAFORSEO_LOGIN=jouw@email.com
DATAFORSEO_PASSWORD=jouw_dataforseo_wachtwoord

# Google API Key - voor PageSpeed Insights (Site Audit)
# Gratis aanmaken op: https://console.cloud.google.com
# Activeer: PageSpeed Insights API
GOOGLE_API_KEY=jouw_google_api_sleutel

# Open PageRank - gratis domein autoriteit score
# Gratis aanmaken op: https://openpagerank.com
OPENPAGERANK_API_KEY=jouw_openpagerank_sleutel

# Flask instellingen
SECRET_KEY=verander-dit-naar-iets-willekeurigs
