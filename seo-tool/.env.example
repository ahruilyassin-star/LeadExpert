# ============================================================
# SEO DASHBOARD v2 — API KEYS
# Kopieer dit bestand naar .env en vul je sleutels in
# ============================================================

# ── DataForSEO — VERPLICHT voor keyword + backlink data ────────
# Aanmaken op: https://dataforseo.com (gratis proefperiode)
# Kosten: ~€0.001-0.003 per query (~€5-15/maand normaal gebruik)
DATAFORSEO_LOGIN=jouw@email.com
DATAFORSEO_PASSWORD=jouw_dataforseo_wachtwoord

# ── Anthropic Claude AI — voor AI features ─────────────────────
# Aanmaken op: https://console.anthropic.com
# Kosten: ~€2-8/maand voor content briefs + clustering
# ZONDER dit werkt alles, maar zonder AI features
ANTHROPIC_API_KEY=sk-ant-...

# ── Google API Key — voor PageSpeed Insights ───────────────────
# Gratis aanmaken op: https://console.cloud.google.com
# Activeer "PageSpeed Insights API" in de API Library
# Zonder key werkt het ook, maar met een lagere rate limit
GOOGLE_API_KEY=AIza...

# ── Flask ───────────────────────────────────────────────────────
SECRET_KEY=verander-dit-naar-iets-willekeurigs-12345
